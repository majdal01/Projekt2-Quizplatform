<template>
  <div class="container">
    <h1>Mine resultater</h1>

    <p v-if="loading" class="loading">Henter resultater...</p>
    <p v-if="error" class="error">{{ error }}</p>

    <table v-if="results.length">
      <thead>
        <tr>
          <th>Dato</th>
          <th>Score</th>
          <th>Korrekte</th>
          <th>Antal spørgsmål</th>
        </tr>
      </thead>
      <tbody>
        <tr v-for="item in results" :key="item.id">
          <td>{{ item.date }}</td>
          <td>{{ item.score }}</td>
          <td>{{ item.correctAnswers }}</td>
          <td>{{ item.totalQuestions }}</td>
        </tr>
      </tbody>
    </table>

    <p v-else-if="!loading">Ingen tidligere resultater fundet.</p>

    <button @click="$router.push('/dashboard')">Tilbage</button>
  </div>
</template>

<script>
import { appStore } from '../stores/appStore'

export default {
  name: 'HistoryView',
  data() {
    return {
      results: [],
      loading: false,
      error: ''
    }
  },
  mounted() {
    this.fetchResults()
  },
  methods: {
    async fetchResults() {
      this.loading = true
      this.error = ''

      try {
        const response = await fetch('/results', {
          headers: {
            Authorization: `Bearer ${appStore.token}`
          }
        })

        if (!response.ok) {
          throw new Error('Kunne ikke hente resultater')
        }

        const data = await response.json()
        this.results = data
      } catch (error) {
        this.error = 'Fejl ved hentning af resultater'
      } finally {
        this.loading = false
      }
    }
  }
}
</script>
