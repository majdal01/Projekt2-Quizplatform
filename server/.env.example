REDIS_URL=redis://127.0.0.1:6379
SESSION_SECRET=replace_with_a_long_random_secret
FRONTEND_ORIGIN=http://localhost:5173
NODE_ENV=development

//Hver teammedlem skal oprette en .env fil i server mappen (cp .env.example .env), og indsætte disse variabler. Hver især skal ændre SESSION_SECRET i lokal .env til en lang og tilfældig streng for at sikre sine sessioner.